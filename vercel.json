{
  "rewrites": [
    {
      "source": "/yamato-tracking/:path*",
      "destination": "/api/yamato-tracking"
    },
    {
      "source": "/japanpost-tracking/:path*",
      "destination": "https://trackings.post.japanpost.jp/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
